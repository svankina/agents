# Machine-specific values referenced by the prompts and skills in this repo.
# Copy to `.env` (gitignored) and fill in for your machine. Committed files
# reference these as $VARS instead of hardcoding personal paths/URLs.

# pi-coding-agent install directory (used by the piagent prompt for doc lookups)
PI_PACKAGE_DIR=~/.hermes/node/lib/node_modules/@earendil-works/pi-coding-agent

# pisaddle checkout (claude-saddle skill's helper-script fallback path)
PISADDLE_DIR=~/src/pisaddle

# claude-design skill ------------------------------------------------------
# Workspace holding design assets / prior-handoff docs
CLAUDE_DESIGN_ASSETS_DIR=~/src/designer
# The app/page URL Claude Design redesigns (your own app)
CLAUDE_DESIGN_APP_URL=https://your-app.example/
# Chrome profile dir for the remote-debugging design session
CLAUDE_DESIGN_CHROME_PROFILE=~/.config/chrome-designer

# context-surgeon prompt ---------------------------------------------------
# URL of the page the context-surgeon agent variant maintains
CONTEXT_SURGEON_URL=https://your-host.example/context-surgeon/
